<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false">
    <!-- Define default log directory if not specified by system property -->
    <property name="LOG_DIR" value="${LOG_DIR:-./.canopy/logs}" />

    <!-- Register custom converter for colored fields (console only) -->
    <conversionRule conversionWord="coloredMsg"
                    converterClass="io.canopy.engine.logging.logback.ColoredFieldsConverter" />

    <!-- ============================================== -->
    <!-- Console Appender (Terminal Output with Colors) -->
    <!-- ============================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Use custom converter %coloredMsg for colored fields -->
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%logger{36})] %coloredMsg%n%ex</pattern>
        </encoder>
    </appender>

    <!-- ============================================== -->
    <!-- Console Appender for WARN/ERROR only          -->
    <!-- ============================================== -->
    <appender name="CONSOLE_ERRORS" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%logger{36})] %coloredMsg%n%ex</pattern>
        </encoder>
    </appender>

    <!-- ============================================== -->
    <!-- File Appender (Plain Text Log File - NO COLORS)-->
    <!-- ============================================== -->
    <appender name="ENGINE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/engine.log</file>
        <immediateFlush>true</immediateFlush>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/engine.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <!-- Use standard %msg - no colors -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app.log</file>
        <immediateFlush>true</immediateFlush>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <!-- Use standard %msg - no colors -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ============================================== -->
    <!-- JSON File Appender (Structured Logs - NO COLORS) jsonl-->
    <!-- ============================================== -->
    <appender name="ENGINE_FILE_JSONL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/engine.jsonl</file>
        <immediateFlush>true</immediateFlush>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/engine.%d{yyyy-MM-dd}.%i.jsonl</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>mdc</includeMdcKeyName>
            <includeContext>true</includeContext>
            <includeCallerData>false</includeCallerData>
        </encoder>
    </appender>

    <appender name="APP_FILE_JSONL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app.jsonl</file>
        <immediateFlush>true</immediateFlush>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/app.%d{yyyy-MM-dd}.%i.jsonl</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>mdc</includeMdcKeyName>
            <includeContext>true</includeContext>
            <includeCallerData>false</includeCallerData>
        </encoder>
    </appender>

    <!-- ============================================== -->
    <!-- Engine Logger (FILE ONLY - No Console)         -->
    <!-- Except WARN/ERROR which go to console too      -->
    <!-- Must come BEFORE generic io.canopy logger      -->
    <!-- ============================================== -->
    <logger name="io.canopy.engine" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE_ERRORS" />
        <appender-ref ref="ENGINE_FILE" />
        <appender-ref ref="ENGINE_FILE_JSONL" />
<!--        <appender-ref ref="SIFT" />-->
<!--        <appender-ref ref="SIFT_JSONL" />-->
    </logger>
    <!-- ============================================== -->
    <!-- Root Logger Configuration                      -->
    <!-- ============================================== -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="APP_FILE" />
        <appender-ref ref="APP_FILE_JSONL" />
<!--        <appender-ref ref="SIFT" />-->
<!--        <appender-ref ref="SIFT_JSONL" />-->
    </root>


    <!-- Reduce noise -->
    <logger name="org.slf4j" level="WARN" />
    <logger name="ch.qos.logback" level="WARN" />

</configuration>

